{
  "name": "nmforge-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "NMforge — Framework Node-nativo de orquestração de agentes para Claude Code 2.1.x. Monorepo root.",
  "author": "Vinicius Caetano <negociosmodernos7@gmail.com>",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md}\"",
    "typecheck": "pnpm -r typecheck",
    "validate": "node packages/cli/bin/nmforge.js validate",
    "validate:strict": "node packages/cli/bin/nmforge.js validate --strict",
    "ci": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^3.0.5",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vitest": "^3.0.5"
  }
}
